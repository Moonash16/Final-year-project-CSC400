<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bubble_background"
        android:padding="2dp">

        <ImageView
            android:id="@+id/bubble_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/shield_icon"
            android:padding="8dp" />

        <LinearLayout
            android:id="@+id/menu_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingEnd="8dp">

            <Button
                android:id="@+id/btn_scan_now"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🔍 SCAN"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_close_bubble"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✖"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F44336"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/result_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/overlay_result_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanning..."
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_confidence_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#EEEEEE"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>